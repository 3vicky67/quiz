projection;
strict ( 2 );
use draft;

define behavior for ZC_Quiz alias Quiz
{
  use create;
  use update;
  use delete;

  use action Edit;
  use action Activate;
  use action Discard;
  use action Resume;
  use action Prepare;


  use association _Questions { create; with draft; }
}

define behavior for ZC_Questions alias Question
{
  use update;
  use delete;

  use association _Quiz { with draft; }
}